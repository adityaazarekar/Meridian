# ─── FRONTEND (.env in project root) ─────────────────────────────────────────
# Local development: point at the local Flask backend
VITE_API_BASE=http://localhost:5000

# Production (Vercel): point at your deployed Render backend URL
# e.g. VITE_API_BASE=https://meridian-backend.onrender.com
# Set this in Vercel Dashboard → Project Settings → Environment Variables


# ─── BACKEND (backend/.env) ───────────────────────────────────────────────────
# Allowed origin for CORS. Set to your Vercel frontend URL on Render dashboard.
# e.g. FRONTEND_URL=https://your-project.vercel.app
FRONTEND_URL=

# Optional: Finnhub API token for company logos (via profile2 endpoint)
# Get a free token at https://finnhub.io/
FINNHUB_TOKEN=

PORT=5000
